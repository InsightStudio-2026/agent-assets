{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "markdownlint: 工作区全量检查",
      "type": "shell",
      "command": "npx",
      "args": [
        "markdownlint-cli2",
        "**/*.md",
        "!frontend/node_modules/**",
        "!.venv/**",
        "!locales/**",
        "!tmp/**",
        "!reports/**"
      ],
      "problemMatcher": [
        "$markdownlint"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "showReuseMessage": false,
        "clear": true
      },
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
